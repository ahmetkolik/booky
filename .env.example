# ─────────────────────────────────────────────────────────────────────────────
#  .env.example  —  copy to .env.local and fill in.
#
#  The guided setup ("/setup" in Claude Code) does this FOR you: it asks which
#  integrations you want, collects each key, and writes .env.local.
#
#  Every key here is OPTIONAL. With none set, Booky runs in DEMO MODE with
#  realistic sample appointments so you can see it immediately.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Supabase (database & auth) ───────────────────────────────────────────────
# Clients, appointments, staff. https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Stripe (deposits & payments) ─────────────────────────────────────────────
# Take a deposit at booking and charge no-show fees. https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Google Calendar (two-way sync) ───────────────────────────────────────────
# Keep staff availability in step with their calendars.
# https://console.cloud.google.com/apis/credentials
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=

# ── Twilio (SMS reminders) ───────────────────────────────────────────────────
# Send appointment reminders and rebooking links. https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
